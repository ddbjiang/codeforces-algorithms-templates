const int MAXN = 1e4+10;
vi g[MAXN];int dfn[MAXN], low[MAXN], tot;//dfn时间戳：记录节点 x 第几个被访问,low追溯值：记录 x 能追溯到的栈中最早的节点
stack<int>stk;int vis[MAXN];//stk用于存储当前搜索路径上的节点,vis标记节点是否在当前栈中
int scc[MAXN], siz[MAXN], cnt;//scc记录每个节点属于哪个SCC,siz记录每个SCC包含的节点数量
void tarjan(int x) {
    dfn[x] = low[x] = tot++;//入x时，盖戳，入栈
    stk.push(x);vis[x] = 1;
    for (int y : g[x]) {
        if (dfn[y] == 0) {//若y尚未访问
            tarjan(y);
            low[x] = min(low[x], low[y]);//回x时更新low
        }
        else if (vis[y] == 1) {//若y已访问且在栈中，更新low
            low[x] = min(low[x], dfn[y]);
        }
    }
    if (dfn[x] == low[x]) {//离x时记录SCC，若x时SCC的根
        int y;cnt++;
        do {
            y = stk.top();stk.pop();
            vis[y] = 0;
            scc[y] = cnt;//SCC编号
            siz[cnt]++;//SCC大小
        } while (y != x);
    }
}
