vvi operator*(const vvi& a, const vvi& b) {
    vvi res(a.size(), vi(b[0].size()));
    for (int i = 0; i < a.size(); i++) {
        for (int j = 0; j < b[0].size(); j++) {
            for (int k = 0; k < a[0].size(); k++) {
                res[i][j] += a[i][k] * b[k][j] % mod;
                res[i][j] %= mod;
            }
        }
    }
    return res;
}
矩阵快速幂（斐波那契ksm(n-1)）
vvi ksm(int k) {
    vvi res = { {1, 0}, {0, 1} };
    vvi g = { {1, 1}, {1, 0} };
    while (k) {
        if (k & 1) {
            res = res * g;
        }
        g = g * g;
        k >>= 1;
    }
    return res;
}

