// 假设 n 是维度，a 是大小为 1<<n 的数组
// 最终 a[mask] 将存储所有 sub <= mask 的异或和
void sos_dp(int n, vector<int>& a) {
    for (int i = 0; i < n; ++i) { // 枚举每一维
        for (int mask = 0; mask < (1 << n); ++mask) {
            if (mask & (1 << i)) { // 如果当前 mask 的第 i 位是 1
                // 累加（异或）上 第 i 位为 0 的那个状态的值
                // mask ^ (1 << i) 就是把第 i 位从 1 变成 0
                a[mask] ^= a[mask ^ (1 << i)];
            }
        }
    }
}

